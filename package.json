{
  "name": "@r-huijts/strava-mcp-server",
  "version": "1.2.1",
  "description": "MCP server for Strava API",
  "mcpName": "io.github.r-huijts/strava-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/r-huijts/strava-mcp"
  },
  "main": "dist/server.js",
  "bin": {
    "strava-mcp-server": "./dist/server.js"
  },
  "type": "module",
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon -L --watch src --ext ts --exec tsx src/server.ts",
    "lint": "eslint . --ext .ts",
    "setup-auth": "tsx scripts/setup-auth.ts",
    "test": "vitest run",
    "test:api": "RUN_API_TESTS=true vitest run tests/getActivityStreams.api.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "strava",
    "llm",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@types/express": "^5.0.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "open": "^10.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^2.1.8"
  }
}
